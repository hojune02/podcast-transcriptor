# ─── Supabase (Expo app) ──────────────────────────────────────────────────────
# Find these in your Supabase project dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

# ─── Supabase Edge Functions ──────────────────────────────────────────────────
# These are set in Supabase dashboard → Settings → Edge Functions → Secrets
# (Never expose these in the mobile app)
SUPABASE_SERVICE_ROLE_KEY=""
# ─── Podcast Index API ────────────────────────────────────────────────────────
# Free API key: https://api.podcastindex.org/
PODCAST_INDEX_API_KEY=""
PODCAST_INDEX_API_SECRET=""

# ─── Groq API ─────────────────────────────────────────────────────────────────
# Free tier available: https://console.groq.com/
GROQ_API_KEY=""

# ─── Modal.com ────────────────────────────────────────────────────────────────
# After deploying with `modal deploy main.py`, copy the webhook URL here.
# Set as a secret in Supabase for the start-transcription edge function.
MODAL_WEBHOOK_URL=

# ─── Modal secrets (set via CLI, not .env) ────────────────────────────────────
# modal secret create podscribe-secrets \
#   SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co \
#   SUPABASE_SERVICE_KEY=your_service_role_key \
#   HUGGINGFACE_TOKEN=hf_xxx  # Optional: needed for speaker diarization
